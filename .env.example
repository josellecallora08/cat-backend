# ===========================================
# CAT Backend Configuration
# ===========================================
# All variables are prefixed with CAT_

# --- Database ---
# SQLite (quick local dev, no setup needed):
CAT_DATABASE_URL=sqlite+aiosqlite:///./cat_dev.db
# PostgreSQL (production):
# CAT_DATABASE_URL=postgresql+asyncpg://your_user@localhost:5432/cat_db

# --- CORS ---
# Comma-separated allowed origins, or "*" for all
CAT_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Debug ---
CAT_DEBUG=true

# --- JWT Authentication ---
CAT_JWT_SECRET=change-this-to-a-random-secret-in-production
CAT_JWT_EXPIRY_HOURS=24

# --- LLM (Groq - OpenAI-compatible API) ---
# Get your key at: https://console.groq.com/keys
CAT_LLM_BASE_URL=https://api.groq.com/openai/v1
CAT_LLM_MODEL=llama-3.3-70b-versatile
CAT_LLM_API_KEY=your-groq-api-key-here
CAT_LLM_TIMEOUT=30.0
CAT_LLM_TEMPERATURE=0.7
CAT_LLM_MAX_TOKENS=1024

# --- ElevenLabs TTS (optional, falls back to gTTS if empty) ---
# Get your key at: https://elevenlabs.io/app/settings/api-keys
CAT_ELEVENLABS_API_KEY=
# Voice ID: browse voices at elevenlabs.io/app/voice-library
# Default "Lily" works well for multilingual/Taglish
CAT_ELEVENLABS_VOICE_ID=pFZP5JQG7iQjIQuC4Bku
