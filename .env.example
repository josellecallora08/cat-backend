# ===========================================
# CAT Backend Configuration
# ===========================================
# All variables are prefixed with CAT_

# --- Database ---
# SQLite (quick local dev, no setup needed):
CAT_DATABASE_URL=sqlite+aiosqlite:///./cat_dev.db
# PostgreSQL (production):
# CAT_DATABASE_URL=postgresql+asyncpg://your_user@localhost:5432/cat_db

# --- CORS ---
# Comma-separated allowed origins, or "*" for all
CAT_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Debug ---
CAT_DEBUG=true

# --- JWT Authentication ---
CAT_JWT_SECRET=change-this-to-a-random-secret-in-production
CAT_JWT_EXPIRY_HOURS=24

# --- LLM (Groq - OpenAI-compatible API) ---
# Get your key at: https://console.groq.com/keys
CAT_LLM_BASE_URL=https://api.groq.com/openai/v1
CAT_LLM_MODEL=llama-3.3-70b-versatile
CAT_LLM_API_KEY=your-groq-api-key-here
CAT_LLM_TIMEOUT=30.0
CAT_LLM_TEMPERATURE=0.7
CAT_LLM_MAX_TOKENS=1024

# --- ElevenLabs TTS (optional, falls back to gTTS if empty) ---
# Get your key at: https://elevenlabs.io/app/settings/api-keys
CAT_ELEVENLABS_API_KEY=
# Voice ID: browse voices at elevenlabs.io/app/voice-library
# Default "Lily" works well for multilingual/Taglish
CAT_ELEVENLABS_VOICE_ID=pFZP5JQG7iQjIQuC4Bku

# --- Lark (Feishu) OAuth ---
# Create an app at: https://open.larksuite.com/app
# Enable "Login with Lark" in Security Settings
CAT_LARK_APP_ID=
CAT_LARK_APP_SECRET=
# Redirect URI must match the one configured in Lark app settings
CAT_LARK_REDIRECT_URI=http://localhost:3000/auth/lark/callback

# --- Google OAuth ---
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Add authorized redirect URI matching CAT_GOOGLE_REDIRECT_URI
CAT_GOOGLE_CLIENT_ID=
CAT_GOOGLE_CLIENT_SECRET=
CAT_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# --- Upload Security Configuration ---
# Maximum file size in bytes (default: 10 MB)
CAT_UPLOAD_MAX_FILE_SIZE=10485760
# Comma-separated list of accepted file extensions (training documents only)
CAT_UPLOAD_ACCEPTED_EXTENSIONS=.pdf,.docx,.txt,.csv,.md
# Directory path for quarantined uploads (relative or absolute)
CAT_UPLOAD_QUARANTINE_PATH=./quarantine
# Hours to retain original files in quarantine before automatic deletion
CAT_UPLOAD_QUARANTINE_RETENTION_HOURS=24
# Interval in minutes between quarantine cleanup runs
CAT_UPLOAD_QUARANTINE_CLEANUP_INTERVAL_MINUTES=60
# Maximum entries allowed inside a DOCX ZIP structure
CAT_UPLOAD_MAX_DOCX_ENTRIES=500
# Maximum total uncompressed size from DOCX ZIP in bytes (default: 50 MB)
CAT_UPLOAD_MAX_DOCX_UNCOMPRESSED_SIZE=52428800
# Maximum nesting depth inside DOCX archives
CAT_UPLOAD_MAX_DOCX_DEPTH=2
# Maximum rejected upload attempts per user within the time window
CAT_UPLOAD_REJECTION_MAX_ATTEMPTS=10
# Time window in minutes for counting rejection attempts
CAT_UPLOAD_REJECTION_WINDOW_MINUTES=60
# Cooldown in minutes after rate limit is triggered
CAT_UPLOAD_REJECTION_COOLDOWN_MINUTES=30
# Enable/disable malware scanning (requires ClamAV daemon)
CAT_UPLOAD_SCANNER_ENABLED=true
# ClamAV daemon socket path
CAT_UPLOAD_SCANNER_SOCKET=/var/run/clamav/clamd.ctl
